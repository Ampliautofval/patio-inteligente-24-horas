# Para testar /api/create-track-manager no PC:
# 1) Copia este ficheiro:  copy .env.example .env.local   (PowerShell)
# 2) Preenche com Project Settings → API no Supabase (URL + service_role)
# 3) No terminal: npm run dev  → abre http://localhost:3000/app.html

SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=cole_aqui_a_service_role_key_secreta
